<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <ImageView
        android:id="@+id/ivCheckoutProductImage"
        android:layout_width="58dp"
        android:layout_height="58dp"
        android:background="@drawable/cart_product_image_bg"
        android:clipToOutline="true"
        android:scaleType="centerCrop"
        android:src="@android:drawable/ic_menu_gallery"
        app:tint="@color/text_muted" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvCheckoutProductName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="Vintage Carhartt Detroit Jacket" />

        <TextView
            android:id="@+id/tvCheckoutSeller"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            tools:text="ThriftKada" />

        <TextView
            android:id="@+id/tvCheckoutQuantity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            tools:text="Qty: 2" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:gravity="end"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvCheckoutPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/primary_maroon"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="PHP 2,400" />

        <TextView
            android:id="@+id/btnReceived"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/premium_badge_bg"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:paddingHorizontal="10dp"
            android:text="@string/received"
            android:textColor="@color/accent_gold"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
