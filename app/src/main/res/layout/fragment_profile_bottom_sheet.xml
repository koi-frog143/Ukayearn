<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/profile_sheet_bg"
    android:clipToPadding="false"
    android:paddingBottom="28dp"
    tools:context=".ui.screens.profile.ProfileBottomSheetFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="12dp"
        android:paddingEnd="24dp">

        <View
            android:layout_width="42dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="22dp"
            android:background="@drawable/profile_sheet_handle" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="64dp"
                android:layout_height="64dp"
                app:cardBackgroundColor="@color/surface_light"
                app:cardCornerRadius="32dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/accent_gold"
                app:strokeWidth="2dp">

                <ImageView
                    android:id="@+id/ivProfilePhoto"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_gravity="center"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_profile_24"
                    app:tint="@color/secondary_blue" />
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvProfileName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/profile_name"
                    android:textColor="@color/black"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvProfileEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="@string/profile_email"
                    android:textColor="@color/text_muted"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvProfileBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/premium_badge_bg"
                    android:gravity="center"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:text="@string/premium_member"
                    android:textColor="@color/accent_gold"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/profile_orders_hint"
            android:textColor="@color/black"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="92dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/profile_stats_bg"
            android:baselineAligned="false"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvProfileStatOneValue"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:background="@drawable/profile_stat_icon_bg"
                    android:gravity="center"
                    android:text="2"
                    android:textColor="@color/secondary_blue"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvProfileStatOneLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/to_ship"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvProfileStatTwoValue"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:background="@drawable/profile_stat_icon_bg"
                    android:gravity="center"
                    android:text="1"
                    android:textColor="@color/secondary_blue"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvProfileStatTwoLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/to_receive"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvProfileStatThreeValue"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:background="@drawable/profile_stat_icon_bg"
                    android:gravity="center"
                    android:text="8"
                    android:textColor="@color/secondary_blue"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvProfileStatThreeLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/completed_orders"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/account_settings"
            android:textColor="@color/black"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/profile_settings_bg"
            android:orientation="vertical"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <include
                android:id="@+id/rowEditProfile"
                layout="@layout/item_profile_setting"
                android:tag="@string/edit_profile" />

            <include
                android:id="@+id/rowDeliveryAddresses"
                layout="@layout/item_profile_setting"
                android:tag="@string/delivery_addresses" />

            <include
                android:id="@+id/rowLogout"
                layout="@layout/item_profile_setting"
                android:tag="@string/logout" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
