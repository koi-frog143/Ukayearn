<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@+id/haggleActionBar"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/haggle_title"
                android:textColor="@color/black"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/haggle_subtitle"
                android:textColor="@color/text_muted"
                android:textSize="13sp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                app:cardBackgroundColor="@color/surface_light"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:background="@drawable/premium_badge_bg"
                        android:gravity="center"
                        android:paddingHorizontal="12dp"
                        android:text="@string/haggle_mode_badge"
                        android:textColor="@color/accent_gold"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/select_cart_item"
                        android:textColor="@color/black"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:layout_marginTop="10dp">

                        <LinearLayout
                            android:id="@+id/pickerCartItem"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/haggle_picker_bg"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="14dp">

                            <TextView
                                android:id="@+id/tvSelectedItemLabel"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:textColor="@color/black"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                tools:text="Vintage Carhartt Detroit Jacket" />

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_chevron_down_24"
                                app:tint="@color/text_muted" />
                        </LinearLayout>

                        <Spinner
                            android:id="@+id/spCartItems"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:alpha="0"
                            android:spinnerMode="dropdown" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="88dp"
                            android:layout_height="88dp"
                            android:background="@drawable/cart_product_image_bg"
                            android:padding="20dp"
                            android:src="@android:drawable/ic_menu_gallery"
                            app:tint="@color/text_muted" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvHaggleProductName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:ellipsize="end"
                                android:maxLines="2"
                                android:textColor="@color/black"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                tools:text="Vintage Carhartt Detroit Jacket" />

                            <TextView
                                android:id="@+id/tvHaggleSeller"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:textColor="@color/text_muted"
                                android:textSize="12sp"
                                tools:text="Seller: ThriftKada" />

                            <TextView
                                android:id="@+id/tvHagglePrice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:textColor="@color/primary_maroon"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                tools:text="PHP 1,200" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/surface_light"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/build_your_offer"
                        android:textColor="@color/black"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="72dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/haggle_summary_bg"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:padding="10dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/current_price"
                                android:textColor="@color/text_muted"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tvCurrentPriceSummary"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:textColor="@color/black"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                tools:text="PHP 1,200" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/your_offer"
                                android:textColor="@color/text_muted"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tvOfferSummary"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/no_offer_yet"
                                android:textColor="@color/primary_maroon"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/btnOfferFive"
                            style="@style/HaggleOfferChip"
                            android:layout_marginEnd="8dp"
                            android:text="@string/offer_five_off" />

                        <TextView
                            android:id="@+id/btnOfferTen"
                            style="@style/HaggleOfferChip"
                            android:layout_marginEnd="8dp"
                            android:text="@string/offer_ten_off" />

                        <TextView
                            android:id="@+id/btnOfferFifteen"
                            style="@style/HaggleOfferChip"
                            android:text="@string/offer_fifteen_off" />
                    </LinearLayout>

                    <EditText
                        android:id="@+id/etOfferAmount"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/search_bg"
                        android:hint="@string/offer_hint"
                        android:inputType="numberDecimal"
                        android:paddingHorizontal="14dp"
                        android:textColor="@color/black"
                        android:textColorHint="@color/text_muted" />

                    <TextView
                        android:id="@+id/tvOfferSavings"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/offer_savings_empty"
                        android:textColor="@color/text_muted"
                        android:textSize="13sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tvHaggleStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/cart_notice_bg"
                android:lineSpacingExtra="3dp"
                android:padding="14dp"
                android:text="@string/haggle_tip"
                android:textColor="@color/text_muted"
                android:textSize="13sp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/haggleActionBar"
        android:layout_width="match_parent"
        android:layout_height="84dp"
        android:background="@color/surface_light"
        android:elevation="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btnSendOffer"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:backgroundTint="@color/primary_maroon"
            android:text="@string/send_offer"
            android:textAllCaps="false"
            android:textColor="@color/white" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
