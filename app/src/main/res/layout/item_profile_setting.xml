<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingEnd="14dp">

    <ImageView
        android:id="@+id/ivProfileSettingIcon"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:src="@drawable/ic_profile_setting_24"
        app:tint="@color/secondary_blue" />

    <TextView
        android:id="@+id/tvProfileSettingTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:textColor="@color/black"
        android:textSize="15sp" />

    <ImageView
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:src="@drawable/ic_chevron_right_24"
        app:tint="@color/text_muted" />
</LinearLayout>
