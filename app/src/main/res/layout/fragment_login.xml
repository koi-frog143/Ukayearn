<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background_light">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="640dp"
        android:padding="24dp">

        <!-- Enhanced Motifs (Green Palette) -->
        <View
            android:id="@+id/authTopMotif"
            android:layout_width="320dp"
            android:layout_height="320dp"
            android:layout_marginTop="-120dp"
            android:layout_marginEnd="-120dp"
            android:alpha="0.8"
            android:background="@drawable/auth_motif_gradient_circle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/authBottomMotif"
            android:layout_width="280dp"
            android:layout_height="280dp"
            android:layout_marginBottom="-140dp"
            android:layout_marginStart="-100dp"
            android:alpha="0.6"
            android:background="@drawable/auth_motif_gradient_circle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Floating leaf motifs behind the cards -->
        <ImageView
            android:id="@+id/authLeafMotif"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_marginTop="-20dp"
            android:layout_marginEnd="10dp"
            android:alpha="0.08"
            android:rotation="-25"
            android:src="@drawable/splash_motif_leaf"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/authLeafMotifBottom"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_marginBottom="40dp"
            android:layout_marginStart="-30dp"
            android:alpha="0.05"
            android:rotation="45"
            android:src="@drawable/splash_motif_leaf"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Small leaf accent randomly floating near title -->
        <ImageView
            android:id="@+id/authLeafMotifMid"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="200dp"
            android:layout_marginEnd="20dp"
            android:alpha="0.04"
            android:rotation="15"
            android:src="@drawable/splash_motif_leaf"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/llHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginTop="32dp"> <!-- Compact padding -->

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@drawable/splashscreen_logo"
                android:layout_marginEnd="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/brand_name"
                android:textColor="@color/earth_forest"
                android:textSize="26sp"
                android:fontFamily="@font/poppins_bold" /> <!-- Bold text, unified green theme -->
        </LinearLayout>

        <ViewFlipper
            android:id="@+id/authFlipper"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/llHeader"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintVertical_bias="0.15">

            <!-- Sign Up Layout (Index 0) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sign_up_account"
                    android:textColor="@color/black"
                    android:textSize="24sp"
                    android:fontFamily="@font/poppins_bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/signup_subtitle"
                    android:textColor="@color/text_muted"
                    android:lineSpacingExtra="2dp"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_light" /> <!-- Body thin -->

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    app:cardBackgroundColor="@color/surface_light"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    app:cardMaxElevation="4dp"> <!-- Sleeker card -->

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/account_details"
                            android:textColor="@color/earth_leaf"
                            android:textSize="14sp"
                            android:fontFamily="@font/poppins_semibold" />
                        
                        <!-- Compact fields (50dp) with light text fonts -->
                        <EditText
                            android:id="@+id/etSignupName"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="14dp"
                            android:background="@drawable/search_bg"
                            android:hint="@string/name_hint"
                            android:inputType="textPersonName"
                            android:paddingStart="18dp"
                            android:paddingEnd="18dp"
                            android:textColor="@color/black"
                            android:textColorHint="@color/text_muted"
                            android:textSize="14sp"
                            android:fontFamily="@font/poppins_light"/>

                        <EditText
                            android:id="@+id/etSignupUsername"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/search_bg"
                            android:hint="@string/username_hint"
                            android:inputType="text"
                            android:paddingStart="18dp"
                            android:paddingEnd="18dp"
                            android:textColor="@color/black"
                            android:textColorHint="@color/text_muted"
                            android:textSize="14sp"
                            android:fontFamily="@font/poppins_light"/>

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/search_bg">
                            <EditText
                                android:id="@+id/etSignupPassword"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@android:color/transparent"
                                android:hint="@string/password_hint"
                                android:inputType="textPassword"
                                android:paddingStart="18dp"
                                android:paddingEnd="50dp"
                                android:textColor="@color/black"
                                android:textColorHint="@color/text_muted"
                                android:textSize="14sp"
                                android:fontFamily="@font/poppins_light"/>
                            <ImageButton
                                android:id="@+id/btnSignupTogglePassword"
                                android:layout_width="50dp"
                                android:layout_height="50dp"
                                android:layout_gravity="end|center_vertical"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="@string/toggle_password_visibility"
                                android:padding="14dp"
                                android:scaleType="centerInside"
                                android:src="@android:drawable/ic_menu_view"
                                app:tint="@color/text_muted" />
                        </FrameLayout>

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/search_bg">
                            <EditText
                                android:id="@+id/etSignupConfirmPassword"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@android:color/transparent"
                                android:hint="@string/confirm_password_hint"
                                android:inputType="textPassword"
                                android:paddingStart="18dp"
                                android:paddingEnd="50dp"
                                android:textColor="@color/black"
                                android:textColorHint="@color/text_muted"
                                android:textSize="14sp"
                                android:fontFamily="@font/poppins_light"/>
                            <ImageButton
                                android:id="@+id/btnSignupToggleConfirmPassword"
                                android:layout_width="50dp"
                                android:layout_height="50dp"
                                android:layout_gravity="end|center_vertical"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="@string/toggle_confirm_password_visibility"
                                android:padding="14dp"
                                android:scaleType="centerInside"
                                android:src="@android:drawable/ic_menu_view"
                                app:tint="@color/text_muted" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvSignupError"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:textColor="@color/error"
                            android:textSize="12sp"
                            android:visibility="gone"
                            android:fontFamily="@font/poppins_light" />

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btnSignup"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="16dp"
                            android:background="@drawable/btn_gradient_primary"
                            app:backgroundTint="@null"
                            android:text="@string/signup"
                            android:fontFamily="@font/poppins_bold"
                            android:textAllCaps="false"
                            android:textSize="15sp"
                            android:textColor="@color/white" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/tvSwitchToLogin"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:text="@string/login_instead"
                    android:textColor="@color/earth_leaf"
                    android:textSize="14sp"
                    android:background="?attr/selectableItemBackground"
                    android:fontFamily="@font/poppins_semibold" />
            </LinearLayout>

            <!-- Log In Layout (Index 1) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/login_title"
                    android:textColor="@color/black"
                    android:textSize="26sp"
                    android:fontFamily="@font/poppins_bold" /> <!-- Header bold -->

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/login_subtitle"
                    android:lineSpacingExtra="2dp"
                    android:textColor="@color/text_muted"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_light" /> <!-- Body thin -->

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    app:cardBackgroundColor="@color/surface_light"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    app:cardMaxElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_logout_24"
                                android:layout_marginEnd="6dp"
                                android:rotation="180"
                                app:tint="@color/earth_leaf" />
                            
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/login_details"
                                android:textColor="@color/earth_leaf"
                                android:textSize="14sp"
                                android:fontFamily="@font/poppins_semibold" />
                        </LinearLayout>

                        <!-- Sleeker Compact fields (50dp height) -->
                        <EditText
                            android:id="@+id/etLoginUsername"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="14dp"
                            android:background="@drawable/search_bg"
                            android:hint="@string/username_hint"
                            android:inputType="text"
                            android:paddingStart="18dp"
                            android:paddingEnd="18dp"
                            android:textColor="@color/black"
                            android:textColorHint="@color/text_muted"
                            android:textSize="14sp"
                            android:fontFamily="@font/poppins_light"/> <!-- Thin for body text -->

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/search_bg">
                            <EditText
                                android:id="@+id/etLoginPassword"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@android:color/transparent"
                                android:hint="@string/password_hint"
                                android:inputType="textPassword"
                                android:paddingStart="18dp"
                                android:paddingEnd="50dp"
                                android:textColor="@color/black"
                                android:textColorHint="@color/text_muted"
                                android:textSize="14sp"
                                android:fontFamily="@font/poppins_light"/> <!-- Thin for body text -->
                            <ImageButton
                                android:id="@+id/btnLoginTogglePassword"
                                android:layout_width="50dp"
                                android:layout_height="50dp"
                                android:layout_gravity="end|center_vertical"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="@string/toggle_password_visibility"
                                android:padding="14dp"
                                android:scaleType="centerInside"
                                android:src="@android:drawable/ic_menu_view"
                                app:tint="@color/text_muted" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvLoginError"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="@string/invalid_credentials"
                            android:textColor="@color/error"
                            android:textSize="12sp"
                            android:visibility="gone"
                            android:fontFamily="@font/poppins_light" />

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btnLogin"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="16dp"
                            android:background="@drawable/btn_gradient_primary"
                            app:backgroundTint="@null"
                            android:text="@string/login"
                            android:fontFamily="@font/poppins_bold"
                            android:textAllCaps="false"
                            android:textSize="15sp"
                            android:textColor="@color/white" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/tvSwitchToSignup"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackground"
                    android:text="@string/already_have_account"
                    android:textColor="@color/earth_leaf"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_semibold" />
            </LinearLayout>
        </ViewFlipper>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>